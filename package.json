{
  "name": "openengine-unity-scene-converter",
  "version": "1.0.0",
  "description": "Converts Unity scenes (from extracted .unitypackage bundles) into OpenEngine/GameEngine text .scene files: static meshes, materials, lights, and scene environment.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lunarsong/OpenEngine-Unity-Scene-Converter.git"
  },
  "main": "src/convert.js",
  "bin": {
    "unity-scene-convert": "bin/unity-scene-convert.js",
    "unity-scene-validate": "bin/unity-scene-validate.js"
  },
  "files": [
    "src/",
    "bin/",
    "shaders/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test \"tests/**/*.test.mjs\""
  }
}
